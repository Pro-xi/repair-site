---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Pro-xi Tech Support — Professional IT Solutions for Home & Business',
  ignoreTitleTemplate: true,
};

const headerData = {
  actions: [
    { text: 'Español', href: '/es', variant: 'tertiary' },
    { variant: 'primary', text: 'Book a Repair', href: 'https://forms.gle/yGBAjNPDYJVJd8acA', icon: 'tabler:tools' },
  ],
};
---

<Layout metadata={metadata} {...headerData}>
  <Hero
  tagline="Hutto's Specialized Tech Support"
  actions={[
    { variant: 'primary', text: 'Book a Repair', href: 'https://forms.gle/yGBAjNPDYJVJd8acA', icon: 'tabler:tools' },
    { text: 'View Services', href: '/services' },
  ]}
>
  <Fragment slot="title">
    Fast, Reliable <span class="text-blue-600 dark:text-blue-400">Hardware Repair</span> for Hutto & Taylor
  </Fragment>

  <Fragment slot="subtitle">
    Specializing in MacBook hinges, broken charging ports, and custom PC builds. 
    Visit our secure 24/7 drop-box on Almquist St.
  </Fragment>
</Hero>

  <Note title="Our Policy:" description="The $80 Flat Rate Diagnostic Fee applies to all services and is fully credited toward your final repair labor." />

  <Prices
    id="pricing"  title="Service Tiers"
    subtitle="Transparent rates. No hidden tech jargon."
    prices={[
      {
        title: 'Diagnostics',
        subtitle: 'The Technical Entry Fee',
        price: 80,
        period: 'Flat Rate',
        items: [
          { description: 'Applied toward your final repair' },
          { description: 'Full hardware stress testing' },
          { description: 'Detailed repair quote provided' },
          { description: 'Root-cause analysis' },
        ],
        callToAction: { text: 'Start Diagnostic', href: '#contact' },
        hasRibbon: true,
        ribbonTitle: 'Most Popular',
      },
      {
        title: 'Computer Repair',
        subtitle: 'Hardware & Deep Fixes',
        price: 100,
        period: 'Base Rate',
        items: [
          { description: 'Includes $80 Diagnostic Fee' },
          { description: 'Laptop Screen Labor ($120)' },
          { description: 'Battery Installation ($100)' },
          { description: 'Fresh OS Installation' },
        ],
        callToAction: { text: 'Book Repair', href: '#contact' },
      },
      {
        title: 'Remote Support',
        subtitle: 'Software & Quick Fixes',
        price: 80,
        period: 'First Hour',
        items: [
          { description: 'Full System Diagnostics' },
          { description: '$50/hr after first hour' },
          { description: 'Work-From-Home Tech Setup' },
          { description: 'Driver & Software Fixes' },
        ],
        callToAction: { variant: 'primary', text: 'Start Remote Session', href: '#contact' },
      },
      {
        title: 'In-Home Support',
        subtitle: 'Printers & Networking',
        price: 150,
        period: 'Starting Rate',
        items: [
          { description: 'Includes $80 Diagnostic Fee' },
          { description: 'Includes $50-$70 Travel Fee' },
          { description: 'Printer & Peripheral Setup' },
          { description: 'Home Wi-Fi & Internet Help' },
        ],
        callToAction: { text: 'Request Visit', href: '#contact' },
      },
    ]}
  />

  <Features
    id="features"
    tagline="Features"
    title="Why Choose Pro-xi?"
    items={[
      {
        title: 'Transparent Pricing',
        description: 'Clear, upfront rates with a guaranteed $80 diagnostic base. No mystery fees or hidden charges.',
        icon: 'tabler:currency-dollar',
      },
      {
        title: '24/7 Secure Drop-Box',
        description: 'Work odd hours? Use our code-protected secure locker for 24-hour drop-offs and pick-ups on your schedule.',
        icon: 'tabler:package-import',
      },
      {
        title: 'Direct Tech Support',
        description: 'No call centers. Speak directly with the technician handling your device via text or phone.',
        icon: 'tabler:user-check',
      },
      {
        title: 'Diagnostic Credit',
        description: 'Your diagnostic fee is applied directly to your final bill, ensuring immediate value for your investment.',
        icon: 'tabler:receipt-2',
      },
      {
        title: 'Fast Turnaround',
        description: 'Most hardware repairs are completed within 48-72 hours of parts arrival. Remote help is often same-day.',
        icon: 'tabler:bolt',
      },
    ]}
  />

  <Steps
    title="Our Simplified Repair Process"
    items={[
     {
        title: 'Step 1: <span class="font-medium">Secure Drop-off or Remote Login</span>',
        description: "Drop your device anytime in our 24-hour, code-protected drop-box for odd-hour convenience, or schedule a remote session.",
        icon: 'tabler:lock-access',
      },
      {
        title: 'Step 2: <span class="font-medium">Repair & Quality Check</span>',
        description: "Once approved, we complete the repair and perform a comprehensive quality check to ensure your tech is running smoothly and reliably.",
        icon: 'tabler:checkup-list',
      },
      {
        title: 'Ready!',
        icon: 'tabler:truck-delivery',
        description: "Pick up your device from the secure locker at your convenience or receive a confirmation for your remote fix!",
      },
    ]}
  />

  <FAQs
    title="Frequently Asked Questions"
    tagline="FAQs"
    items={[
      {
        title: 'What does the $80 Diagnostic Fee cover?',
        description: 'It covers our time to open the device, test components, and research specific part compatibility. This fee is credited toward your repair if you move forward.',
      },
      {
        title: 'Why do you need my laptop model and year?',
        description: 'Parts vary wildly between years. Knowing your specific model allows us to give you a 100% accurate quote on screens, batteries, or hinges before you even arrive.',
      },
      {
        title: 'Do you work with local businesses?',
        description: 'Yes! We help local shops with printer setups, office networking, and device refreshes without requiring a monthly contract.',
      },
      {
        title: "Are replacement parts included in the price?",
        description: "The prices listed cover labor and diagnostics. Replacement parts (like screens, batteries, or SSDs) are billed separately based on current market cost. We always provide a firm quote for parts and get your approval before ordering anything.",
      },
    {
      title: 'Where are you located?',
      description:
        'We are located at **226 Almquist St, Hutto, TX 78634**. We are conveniently situated to serve Hutto, Taylor, and the surrounding Williamson County area.',
    },
    {
      title: 'Do you do house calls or on-site repairs?',
      description:
        'Yes! We provide on-site tech support for homes and small businesses in Hutto and Taylor. Whether it’s a networking issue, printer setup, or a desktop that is too heavy to move, we come to you.',
    },
    {
      title: 'How long do repairs typically take?',
      description:
        'Most software tune-ups and common hardware fixes are completed within **24 to 48 hours**. If a specialty part (like a specific laptop screen or hinge) needs to be ordered, we will give you an exact timeline upfront.',
    },
    {
      title: 'How does the 24/7 Secure Drop-Box work?',
      description:
        'It’s designed for your busy schedule. Once you [request a repair](https://forms.gle/yGBAjNPDYJVJd8acA), you will receive a secure code to access our monitored drop-box on Almquist St at any time—day or night.',
    },
    {
      title: 'Can you fix a broken laptop hinge or cracked casing?',
      description:
        'Absolutely. This is one of our core specialties. We reinforce internal mounts and replace damaged hinges to ensure your screen opens and closes smoothly again without further damage.',
    },
  ]}
  />

  <CallToAction
    id="contact"
    actions={[
      {
        variant: 'primary',
        text: 'Fill out Repair Form',
        href: 'https://forms.gle/ENmcpVyRyrcUZceM6',
        target: '_blank',
        icon: 'tabler:forms',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to fix your tech?
    </Fragment>
    <Fragment slot="subtitle">
      Contact us today for a free estimate. Your IT solutions are just a click away.
    </Fragment>
  </CallToAction>
</Layout>