---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import { Image } from 'astro:assets';

// 1. Importing your actual images from src/assets/images/
import brokenPort from '~/assets/images/Broken-Port.jpg';
import hinge1 from '~/assets/images/Hinge1.jpg';
import lenovoHinge from '~/assets/images/Lenovo-Broken-Hinge.jpg';
import oldServer from '~/assets/images/Old-Server.jpg';

const metadata = {
  title: 'Gallery | Pro-Xi Tech Support Repairs',
};

// 2. Mapping your images to labels and descriptions
const photos = [
  { 
    src: brokenPort, 
    alt: 'Broken charging port repair Hutto', 
    label: 'Port Repair', 
    desc: 'Replacing damaged DC jacks and USB-C ports.' 
  },
  { 
    src: hinge1, 
    alt: 'Laptop hinge structural repair', 
    label: 'Hinge Fix', 
    desc: 'Reinforcing mechanical pivots for smooth opening.' 
  },
  { 
    src: lenovoHinge, 
    alt: 'Lenovo laptop hinge repair Taylor', 
    label: 'Lenovo Specialist', 
    desc: 'Common structural repairs for Lenovo laptops.' 
  },
  { 
    src: oldServer, 
    alt: 'Old server decommissioning and data recovery', 
    label: 'Legacy Support', 
    desc: 'Data migration and server decommissioning services.' 
  },
];
---

<Layout metadata={metadata}>
  <HeroText title="Our Work" tagline="Real repairs for Hutto & Taylor residents" />

  <section class="px-4 py-16 mx-auto max-w-6xl lg:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
      {photos.map((photo) => (
        <div class="group relative rounded-xl overflow-hidden shadow-lg bg-black">
          <Image 
            src={photo.src} 
            alt={photo.alt} 
            class="w-full h-80 object-cover group-hover:opacity-60 transition-opacity duration-300"
          />

          <div class="absolute top-4 right-4 bg-white/20 backdrop-blur-md px-2 py-1 rounded text-[10px] font-bold uppercase tracking-widest text-white/70 border border-white/10 pointer-events-none select-none z-10">
            © PRO-XI REPAIR
          </div>
          
          <div class="absolute inset-0 flex flex-col justify-end p-6 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300 bg-gradient-to-t from-black/90 via-transparent to-transparent">
            <span class="text-blue-400 font-bold uppercase tracking-wider text-sm mb-1">{photo.label}</span>
            <h3 class="text-white text-xl font-bold">{photo.desc}</h3>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-muted mb-4 italic">Providing expert tech support to the 78634 and 76574 area codes.</p>
      <a href="/contact" class="bg-blue-600 hover:bg-blue-700 text-white font-bold px-8 py-3 rounded-lg transition-colors inline-block">
        Request a Repair Estimate
      </a>
    </div>
  </section>
</Layout>