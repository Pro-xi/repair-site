---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact Pro-xi Tech Support',
};
---

<Layout metadata={metadata}>
  <HeroText tagline="Contact" title="Let's Get You Back Online" />

  <ContactUs
    id="form"
    title="Send a Quick Message"
    subtitle="Have a general question? Drop it here. For hardware repairs, use our Google Form below for a faster estimate."
    inputs={[
      { type: 'text', name: 'name', label: 'Name' },
      { type: 'email', name: 'email', label: 'Email' },
    ]}
    textarea={{ label: 'How can we help?' }}
    description="We typically respond within 2 hours during business hours."
  />

  <section class="px-4 py-12 bg-blue-50 dark:bg-slate-800/50">
    <div class="max-w-3xl mx-auto text-center mb-8">
      <h2 class="text-3xl font-bold italic text-blue-600 dark:text-blue-400">Detailed Repair Request</h2>
      <p class="text-muted mt-2">Provide your device details below for a more accurate quote.</p>
    </div>
    <div class="flex justify-center">
      <div class="w-full max-w-[700px] bg-white dark:bg-slate-900 rounded-xl shadow-2xl overflow-hidden border border-gray-200 dark:border-gray-700">
        <iframe 
          src="https://docs.google.com/forms/d/e/1FAIpQLSdMfDow8DVF4KCjKzrvZmKRyw6xgj4ZbSamBxRBEPOLJvMdcA/viewform?embedded=true" 
          width="100%" 
          height="1250" 
          frameborder="0" 
          marginheight="0" 
          marginwidth="0"
          class="bg-white"
        >Loading…</iframe>
      </div>
    </div>
  </section>

  <Features2
    title="Ways to reach us"
    items={[
      {
        title: 'Phone / Text',
        description:
          '<a href="tel:5127663825" class="text-blue-600 font-bold hover:underline">512-766-3825</a> <br /> <span class="text-sm">Call or Text for immediate service in Hutto.</span>',
        icon: 'tabler:headset',
      },
      {
        title: 'Repair Request (Fastest)',
        description:
          'Fill out the form above for a detailed quote.',
        icon: 'tabler:forms',
      },
      {
        title: '24/7 Secure Drop-Box',
        description:
          'Drop off your device at 226 Almquist St at any hour. Contact us first for your unique access code.',
        icon: 'tabler:lock-access',
      },
      {
        title: 'Location',
        description: '226 Almquist St, Hutto, TX 78634 <br /> <span class="text-sm">Located in the heart of Hutto.</span>',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Email',
        description: 'admin@pro-xi.com',
        icon: 'tabler:mail',
      },
      {
        title: 'Service Hours',
        description: 'Mon - Fri: 9am - 5pm <br /> Sat: 10am - 4pm',
        icon: 'tabler:clock',
      },
    ]}
  />
</Layout>