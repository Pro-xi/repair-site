---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

// Add the header toggle to go back to English
const headerData = {
  // 1. This translates the actual menu links
  links: [
    { text: 'Inicio', href: '/es' },
    { text: 'Servicios', href: '/es/services' },
    { text: 'Contacto', href: '/es/contact' },
    { text: 'Blog', href: '/blog' }, // Keep blog in English or link to Spanish category
  ],
  // 2. This translates the button and the language toggle
  actions: [
    { text: 'English', href: '/', variant: 'tertiary' },
    { variant: 'primary', text: 'Reservar Reparación', href: 'https://forms.gle/yGBAjNPDYJVJd8acA', icon: 'tabler:tools' },
  ],
};

const metadata = {
  title: 'Contacto - Pro-xi Tech Support',
};
---

<Layout metadata={metadata} {...headerData}>
  <HeroText tagline="Contacto" title="Permítanos Ayudarle a Volver a Estar en Línea" />

  <ContactUs
    id="form"
    title="Envíe un Mensaje Rápido"
    subtitle="¿Tiene una pregunta general? Escríbanos aquí. Para reparaciones de hardware, use el formulario de Google a continuación para obtener un presupuesto más rápido."
    inputs={[
      { type: 'text', name: 'name', label: 'Nombre' },
      { type: 'email', name: 'email', label: 'Correo Electrónico' },
    ]}
    textarea={{ label: '¿En qué podemos ayudarle?' }}
    description="Normalmente respondemos en menos de 2 horas durante el horario laboral."
  />

  <section class="px-4 py-12 bg-blue-50 dark:bg-slate-800/50">
    <div class="max-w-3xl mx-auto text-center mb-8">
      <h2 class="text-3xl font-bold italic text-blue-600 dark:text-blue-400">Solicitud de Reparación Detallada</h2>
      <p class="text-muted mt-2">Proporcione los detalles de su dispositivo a continuación para una cotización más precisa.</p>
    </div>
    <div class="flex justify-center">
      <div class="w-full max-w-[700px] bg-white dark:bg-slate-900 rounded-xl shadow-2xl overflow-hidden border border-gray-200 dark:border-gray-700">
        <iframe 
          src="https://docs.google.com/forms/d/e/1FAIpQLSdMfDow8DVF4KCjKzrvZmKRyw6xgj4ZbSamBxRBEPOLJvMdcA/viewform?embedded=true" 
          width="100%" 
          height="1250" 
          frameborder="0" 
          marginheight="0" 
          marginwidth="0"
          class="bg-white"
        >Cargando…</iframe>
      </div>
    </div>
  </section>

  <Features2
    title="Formas de contactarnos"
    items={[
      {
        title: 'Teléfono / Texto',
        description:
          '<a href="tel:5127663825" class="text-blue-600 font-bold hover:underline">512-766-3825</a> <br /> <span class="text-sm">Llámenos o envíe un texto para servicio inmediato en Hutto.</span>',
        icon: 'tabler:headset',
      },
      {
        title: 'Solicitud de Reparación (Más rápido)',
        description:
          'Llene el formulario de arriba para obtener una cotización detallada.',
        icon: 'tabler:forms',
      },
      {
        title: 'Buzón Seguro 24/7',
        description:
          'Entregue su dispositivo en 226 Almquist St a cualquier hora. Contáctenos primero para su código de acceso único.',
        icon: 'tabler:lock-access',
      },
      {
        title: 'Ubicación',
        description: '226 Almquist St, Hutto, TX 78634 <br /> <span class="text-sm">Ubicados en el corazón de Hutto.</span>',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Correo Electrónico',
        description: 'admin@pro-xi.com',
        icon: 'tabler:mail',
      },
      {
        title: 'Horario de Servicio',
        description: 'Lun - Vie: 9am - 5pm <br /> Sáb: 10am - 4pm',
        icon: 'tabler:clock',
      },
    ]}
  />
</Layout>